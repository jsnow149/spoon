{
    "version": "2.01",
    "homepage": "https://www.nirsoft.net/utils/shexview.html",
    "bin": "shexview.exe",
    "shortcuts": [
        [
            "shexview.exe",
            "NirSoft\\ShellExView"
        ]
    ],
    "pre_install": [
        "if (!(Test-Path \"$dir\\shexview_lng.ini\" -ErrorAction SilentlyContinue)) {",
        "    Write-Host 'Creating shexview_lng.ini (first run).' -f Yellow",
        "    Start-Process -FilePath \"$dir\\shexview.exe\"",
        "    while (!(Test-Path \"$dir\\shexview_lng.ini\" -ErrorAction SilentlyContinue) -and !(Test-Path \"$dir\\shexview.cfg\" -ErrorAction SilentlyContinue)) {",
        "        Start-Sleep -Milliseconds 500",
        "    }",
        "    Start-Sleep 1",
        "    Stop-Process -Name shexview -Force -ErrorAction SilentlyContinue",
        "}",
        "if (!(Test-Path \"$dir\\shexview.cfg\" -ErrorAction SilentlyContinue)) {",
        "    Write-Host 'Creating shexview.cfg (second run if needed).' -f Yellow",
        "    Start-Process -FilePath \"$dir\\shexview.exe\"",
        "    while (!(Test-Path \"$dir\\shexview.cfg\" -ErrorAction SilentlyContinue)) {",
        "        Start-Sleep -Milliseconds 500",
        "    }",
        "    Start-Sleep 1",
        "    Stop-Process -Name shexview -Force -ErrorAction SilentlyContinue",
        "}"
    ],
    "persist": [
        "shexview_lng.ini",
        "shexview.cfg"
    ],
    "architecture": {
        "64bit": {
            "url": "https://www.nirsoft.net/utils/shexview-x64.zip",
            "hash": "73248fb48ee6387cadbd6bdde5265cbef465cea7fca8f3b72eac5c408f4e7ccb"
        },
        "32bit": {
            "url": "https://www.nirsoft.net/utils/shexview.zip",
            "hash": "b0f5e6bea715be67460d24e4ffe5256297ffd990cc4f5bfa902f9d5af0d1196d"
        }
    },
    "description": "Displays the details of shell extensions installed on your computer.",
    "license": "Freeware",
    "notes": "If this application is useful to you, please consider donating to NirSoft - https://www.nirsoft.net/donate.html",
    "checkver": {
        "url": "https://www.nirsoft.net/pad/shexview.xml",
        "xpath": "/XML_DIZ_INFO/Program_Info/Program_Version"
    },
    "autoupdate": {
