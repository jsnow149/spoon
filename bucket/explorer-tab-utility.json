{
    "version": "2.5.0",
    "description": "Explorer Tab Utility: Force new windows to tabs. Streamline navigation!",
    "homepage": "https://github.com/w4po/ExplorerTabUtility",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v2.5.0/ExplorerTabUtility_v2.5.0_x64_Net9.0_FrameworkDependent.zip",
            "hash": "7b16a202941342cd31090ec9b173db1f15ef02d1a79daf79e9278c1c16c953cd"
        },
        "32bit": {
            "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v2.5.0/ExplorerTabUtility_v2.5.0_x86_Net9.0_FrameworkDependent.zip",
            "hash": "b4566c009fee805cc8a729adb47bfce1385e15a4eb5665919d8b306a91fa3cb9"
        }
    },
    "extract_dir": "ExplorerTabUtility",
    "post_install": [
        "if (!(Test-Path -Path $persist_dir -PathType Container)) {",
        "    New-Item -Path $persist_dir -ItemType Directory -Force | Out-Null",
        "}",
        "$persists = @('ExplorerTabUtility.exe.config')",
        "foreach ($file in $persists) {",
        "    $src = Join-Path -Path $dir -ChildPath $file",
        "    $target = Join-Path -Path $persist_dir -ChildPath $file",
        "    if (!(Test-Path -Path $target -PathType Leaf)) {",
        "        if (Test-Path -Path $src -PathType Leaf) {",
        "            Move-Item -Path $src -Destination $target -Force",
        "        } else {",
        "           New-Item -Path $target -ItemType File",
        "        }",
        "    }",
        "    Remove-Item -Path $src -Force -ErrorAction SilentlyContinue",
        "    New-Item -ItemType SymbolicLink -Path $src -Target $target",
        "}"
    ],
    "shortcuts": [
        [
            "ExplorerTabUtility.exe",
            "ExplorerTabUtility"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v$version/ExplorerTabUtility_v$version_x64_Net9.0_FrameworkDependent.zip"
            },
            "32bit": {
                "url": "https://github.com/w4po/ExplorerTabUtility/releases/download/v$version/ExplorerTabUtility_v$version_x86_Net9.0_FrameworkDependent.zip"
            }
        }
    }
}
